{
  "schema_version": 1,
  "id": "aec-vad-playback-reference-mini-v1",
  "description": "Tiny synthesized (non-secret, deterministic) playback-reference fixtures for offline VAD/AEC bakeoffs. Each fixture carries an aligned mic/system capture track AND an assistant render-reference track so a pre-bus AEC stage can subtract playback echo before the canonical 16 kHz ProcessedAudioChunk bus.",
  "format": {
    "container": "wav",
    "encoding": "pcm_s16le",
    "sample_rate": 16000,
    "channels": 1,
    "bit_depth": 16
  },
  "provenance": {
    "kind": "synthesized",
    "secret_free": true,
    "deterministic": true,
    "generator": "src-tauri/src/aec_vad/mod.rs::synthesize_fixture",
    "notes": [
      "All tracks are synthesized from sine tones and a seeded xorshift64* noise source — no recorded audio, no third-party dataset, no secrets.",
      "Regenerate with the offline validator (src-tauri/src/aec_vad_fixtures.rs), which writes any missing WAV from the synthesizer and is byte-for-byte reproducible.",
      "Render-reference is the assistant playback twin; capture is what the device hears (echo of the render plus any user/noise). The two tracks share a sample-aligned timebase (capture_start_ms == reference_start_ms == 0)."
    ]
  },
  "seam": {
    "aec_runs_before_processed_bus": true,
    "processed_bus_sample_rate_hz": 16000,
    "alignment_primitive": "ProcessedAudioChunk.timestamp",
    "must_not_mutate_asr_chunks": true,
    "render_reference_source": "playback::AudioPlayer (PlaybackConfig::source_sample_rate default 24000, resampled to 16000 for the fixture)",
    "real_candidate_owned_by_seed": "audio-graph-0bdc"
  },
